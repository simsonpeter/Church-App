{
  "functions": {
    "api/sermon-og/[hash].js": {
      "memory": 1024,
      "maxDuration": 20
    }
  },
  "rewrites": [
    {
      "source": "/.well-known/assetlinks.json",
      "destination": "/well-known/assetlinks.json"
    },
    {
      "source": "/share/sermon/:hash",
      "destination": "/api/share/:hash"
    }
  ]
}
