rules_version = '2';
// Paths used by Church-App (songbook-add54 / profile-page.js, user-auth.js, home-page.js):
//   users/{uid}/profile/basic  — profile fields + triviaPoints (merge)
//   users/{uid}/app/state      — reading progress, sermon favorites
//
// Deploy: firebase deploy --only firestore:rules
// Or paste into Firebase console → Firestore → Rules.

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId}/profile/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/app/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Public leaderboard rows (one doc per Firebase uid). Anyone can read;
    // only the signed-in user may create/update/delete their own doc.
    // Used by app-shell.js (NjcAchievementBoard) and user-achievements-page.js.
    match /userAchievementScores/{userId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
