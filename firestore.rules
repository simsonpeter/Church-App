rules_version = '2';
//
// === PASTE INTO FIREBASE (whole file) =====================================
// 1) GitHub → Church-App → firestore.rules → open file → Raw → Select all → Copy
// 2) Firebase Console → Firestore Database → Rules → Select all → Paste → Publish
// No need to search or edit snippets; this file is the full ruleset for this app.
// Exception: if your Firebase project has EXTRA collections not listed below,
// do not replace blindly — merge those matches in or you may break other tools.
// =============================================================================
//
// Church-App Firestore paths:
//   appConfig/modules          — feature toggles (public read; admin write): { flags: { ... }, updatedAt }
//   userAccess/{uid}           — optional per-user access: { accessType, allowedModules, updatedAt }; user reads own; admin writes
//   lyrics/{songId}            — NJC Songbook (church app reads via Firebase SDK)
//   serviceSongs/{id}          — ordered list for “Service” tab
//   userDirectory/{uid}        — one doc per email user (admin lists all; user upserts own; admin may fix displayName/email)
//   users/{uid}/profile/basic  — profile (incl. optional familyMembers[], optional visibleModules[]) + triviaPoints (merge)
//   users/{uid}/app/state      — reading progress, sermon favorites
//   users/{uid}/app/access     — member (default new signup) or limited + module picks; member code redeem via Cloud Function
//   appConfig/access           — registrationPool: which modules new users may pick at signup (public read)
//   appConfig/memberCodes      — one-time church member codes (admin read/write only)
//   userAchievementScores/{uid} — public leaderboard (read all; write own doc only)
//   celebrationWishes/{msgId} — daily thread (registered member read; create/delete when signed in)
//   celebrationProfiles/{uid} — celebration fields; registered member read (token.email); owner write
//   chatMessages/{msgId} — church group chat: text only, signed-in users
//   adminTriviaReports/{uid} — per-user trivia answers for admin dashboard (owner write; admin read)
//
// If "User achievements" shows "Public read is blocked", this file is not published
// for THIS Firebase project yet. Fix:
//   1) Firebase console → Firestore Database → Rules (not Version history)
//   2) Ensure the userAchievementScores block below is present, then Publish.
//   3) Or from repo: firebase deploy --only firestore:rules
// If you already have other match rules in production, ADD this block; do not delete
// your existing matches unless you intend to replace the whole file with this one.

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.lower() == "simsonpeter@gmail.com";
    }

    // Email/password (or OAuth) users have token.email; anonymous sessions do not — keeps celebrations off non-registered clients.
    function isRegisteredMember() {
      return request.auth != null
        && request.auth.token.email is string
        && request.auth.token.email.size() > 0;
    }

    // App-wide feature toggles + registration pool + member codes under appConfig/{docId}.
    match /appConfig/{docId} {
      allow read: if docId != "memberCodes" || isAdmin();
      // Note: do not require updatedAt is timestamp — FieldValue.serverTimestamp() is a sentinel
      // during rule evaluation and fails timestamp checks (same pattern as celebrationWishes create).
      allow create: if isAdmin() && (
        (docId == "modules"
          && request.resource.data.keys().hasOnly(["flags", "updatedAt"])
          && request.resource.data.flags is map
          && request.resource.data.flags.size() <= 40)
        || (docId == "access"
          && request.resource.data.keys().hasOnly(["registrationPool", "updatedAt"])
          && request.resource.data.registrationPool is map
          && request.resource.data.registrationPool.size() <= 40)
        || (docId == "memberCodes"
          && request.resource.data.keys().hasOnly(["codes", "updatedAt"])
          && request.resource.data.codes is list
          && request.resource.data.codes.size() <= 500)
      );
      allow update: if isAdmin() && (
        (docId == "modules"
          && request.resource.data.flags is map
          && request.resource.data.flags.size() <= 40)
        || (docId == "access"
          && request.resource.data.registrationPool is map
          && request.resource.data.registrationPool.size() <= 40)
        || (docId == "memberCodes"
          && request.resource.data.codes is list
          && request.resource.data.codes.size() <= 500)
      );
      allow delete: if false;
    }

    function isUserAccessPayload() {
      return request.resource.data.keys().hasOnly(["accessType", "allowedModules", "updatedAt"])
        && request.resource.data.accessType is string
        && (request.resource.data.accessType == "church" || request.resource.data.accessType == "limited")
        && request.resource.data.allowedModules is list
        && request.resource.data.allowedModules.size() <= 40
        && request.resource.data.updatedAt is timestamp;
    }

    // Per-user module access (limited members). Signed-in user may read own doc; admin may read/write any.
    match /userAccess/{userId} {
      allow read: if request.auth != null
        && (request.auth.uid == userId || isAdmin());
      allow create, update: if isAdmin() && isUserAccessPayload();
      allow delete: if isAdmin();
    }

    function isUserDirectoryDocument() {
      return request.resource.data.keys().hasOnly(["displayName", "email", "lastSeenAt", "updatedAt"])
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() > 0
        && request.resource.data.displayName.size() <= 120
        && request.resource.data.email is string
        && request.resource.data.email == request.auth.token.email.lower()
        && request.resource.data.lastSeenAt is timestamp
        && request.resource.data.updatedAt is timestamp;
    }

    // Admin may correct directory rows (e.g. display name from profile) without matching token email.
    function isAdminUserDirectoryDocument() {
      return request.resource.data.keys().hasOnly(["displayName", "email", "lastSeenAt", "updatedAt"])
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() > 0
        && request.resource.data.displayName.size() <= 120
        && request.resource.data.email is string
        && request.resource.data.email.size() > 3
        && request.resource.data.email.size() <= 320
        && request.resource.data.lastSeenAt is timestamp
        && request.resource.data.updatedAt is timestamp;
    }

    match /userDirectory/{userId} {
      allow read: if isAdmin();
      allow create, update: if (request.auth != null
        && request.auth.uid == userId
        && isUserDirectoryDocument())
        || (isAdmin() && isAdminUserDirectoryDocument());
      allow delete: if false;
    }

    // Songbook (written from NJC Song / admin tools; church app loads with Firebase SDK).
    match /lyrics/{songId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    function isProfileBasicFamilyMember(m) {
      return m.keys().hasOnly(["id", "name", "dob"])
        && m.id is string
        && m.id.size() > 0
        && m.id.size() <= 64
        && m.name is string
        && m.name.size() > 0
        && m.name.size() <= 120
        && m.dob is string
        && m.dob.size() <= 12;
    }

    // Merge-friendly profile doc: same fields as client save, plus optional trivia/reading points (home-page sync).
    function isProfileBasicPayload() {
      return request.resource.data.keys().hasOnly([
          "fullName", "dob", "anniversary", "anniversaryPartnerName", "familyMembers",
          "phone", "groupId", "leaderboardAnonymous", "photoSkipCloud", "visibleModules",
          "photoUrl", "triviaPoints", "readingPoints", "updatedAt"
        ])
        && (!request.resource.data.keys().hasAny(["fullName"])
          || (request.resource.data.fullName is string && request.resource.data.fullName.size() <= 120))
        && (!request.resource.data.keys().hasAny(["dob"])
          || (request.resource.data.dob is string && request.resource.data.dob.size() <= 12))
        && (!request.resource.data.keys().hasAny(["anniversary"])
          || (request.resource.data.anniversary is string && request.resource.data.anniversary.size() <= 12))
        && (!request.resource.data.keys().hasAny(["anniversaryPartnerName"])
          || (request.resource.data.anniversaryPartnerName is string
            && request.resource.data.anniversaryPartnerName.size() <= 120))
        && (!request.resource.data.keys().hasAny(["phone"])
          || (request.resource.data.phone is string && request.resource.data.phone.size() <= 40))
        && (!request.resource.data.keys().hasAny(["groupId"])
          || (request.resource.data.groupId is string && request.resource.data.groupId.size() <= 80))
        && (!request.resource.data.keys().hasAny(["leaderboardAnonymous"])
          || request.resource.data.leaderboardAnonymous is bool)
        && (!request.resource.data.keys().hasAny(["photoSkipCloud"])
          || request.resource.data.photoSkipCloud is bool)
        && (!request.resource.data.keys().hasAny(["visibleModules"])
          || (request.resource.data.visibleModules is list
            && request.resource.data.visibleModules.size() <= 30))
        && (!request.resource.data.keys().hasAny(["photoUrl"])
          || (request.resource.data.photoUrl is string
            && request.resource.data.photoUrl.size() <= 800000))
        && (!request.resource.data.keys().hasAny(["triviaPoints"])
          || (request.resource.data.triviaPoints is int
            && request.resource.data.triviaPoints >= 0
            && request.resource.data.triviaPoints <= 1000000))
        && (!request.resource.data.keys().hasAny(["readingPoints"])
          || (request.resource.data.readingPoints is int
            && request.resource.data.readingPoints >= 0
            && request.resource.data.readingPoints <= 1000000))
        && request.resource.data.updatedAt is timestamp
        && (!request.resource.data.keys().hasAny(["familyMembers"])
          || (request.resource.data.familyMembers is list
            && request.resource.data.familyMembers.size() <= 20
            && request.resource.data.familyMembers.size() > 0
              ? request.resource.data.familyMembers[0] is map && isProfileBasicFamilyMember(request.resource.data.familyMembers[0])
            : true));
    }

    match /users/{userId}/profile/{docId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create, update: if (request.auth != null && request.auth.uid == userId)
        || (isAdmin() && docId == "basic" && isProfileBasicPayload());
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // App state: reading progress, sermon favorites, lastSeen (synced from user-auth).
    function isUserAppStatePayload() {
      return (!request.resource.data.keys().hasAny(["updatedAt"])
          || (request.resource.data.updatedAt is int
            && request.resource.data.updatedAt > 0
            && request.resource.data.updatedAt < 2000000000000))
        && (!request.resource.data.keys().hasAny(["lastSeenAt"])
          || request.resource.data.lastSeenAt is timestamp)
        && (!request.resource.data.keys().hasAny(["readingProgress"])
          || request.resource.data.readingProgress is map)
        && (!request.resource.data.keys().hasAny(["sermonFavorites"])
          || request.resource.data.sermonFavorites is map);
    }

    match /users/{userId}/app/state {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create, update: if (request.auth != null && request.auth.uid == userId)
        || (isAdmin() && isUserAppStatePayload());
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    function isUserAppAccessPayload() {
      return request.resource.data.keys().hasOnly(["accessTier", "moduleGrants", "updatedAt"])
        && request.resource.data.accessTier is string
        && (request.resource.data.accessTier == "member" || request.resource.data.accessTier == "limited")
        && request.resource.data.moduleGrants is map
        && request.resource.data.moduleGrants.size() <= 25
        && request.resource.data.moduleGrants.keys().hasOnly([
          "announcements", "bibleReading", "dailyVerse", "trivia", "eventsWeek",
          "dailyBread", "bookShelf", "bible", "songbook", "prayer", "events",
          "sermons", "contact", "celebrations", "chat", "userAchievements"
        ])
        && request.resource.data.updatedAt is timestamp;
    }

    match /users/{userId}/app/access {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      // First-time signup (self, doc missing): member or limited + module picks (see isUserAppAccessPayload).
      // Admin "Grant member access" / "Set member" uses merge — same payload helper as updates.
      allow create: if (request.auth != null
        && request.auth.uid == userId
        && !exists(/databases/$(database)/documents/users/$(userId)/app/access)
        && isUserAppAccessPayload())
        || (isAdmin() && isUserAppAccessPayload());
      // Owner may downgrade member → limited (normal user plus); upgrades stay admin/code only.
      allow update: if isAdmin() && isUserAppAccessPayload()
        || (request.auth != null
          && request.auth.uid == userId
          && resource.data.accessTier == "member"
          && request.resource.data.accessTier == "limited"
          && isUserAppAccessPayload());
      allow delete: if isAdmin();
    }

    // Public leaderboard rows (one doc per Firebase uid). Anyone can read;
    // only the signed-in user may create/update/delete their own doc.
    // Used by app-shell.js (NjcAchievementBoard) and user-achievements-page.js.
    match /userAchievementScores/{userId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && request.auth.uid == userId;
    }

    match /adminTriviaReports/{userId} {
      allow read: if isAdmin();
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.correctCount is int
        && request.resource.data.correctCount >= 0
        && request.resource.data.correctCount <= 10000
        && request.resource.data.wrongCount is int
        && request.resource.data.wrongCount >= 0
        && request.resource.data.wrongCount <= 10000
        && request.resource.data.lastQuizDate is string
        && request.resource.data.lastQuizDate.size() <= 12
        && request.resource.data.lastResult is string
        && (request.resource.data.lastResult == "correct"
            || request.resource.data.lastResult == "wrong"
            || request.resource.data.lastResult == "")
        && request.resource.data.lastUpdatedAt is timestamp
        && (!request.resource.data.keys().hasAny(["triviaByDate"])
            || request.resource.data.triviaByDate is map);
      allow delete: if false;
    }

    // FCM device tokens for push (one doc per uid). Only Cloud Functions read; user writes own token.
    match /fcmTokens/{userId} {
      allow read: if false;
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.token is string
        && request.resource.data.token.size() > 20
        && request.resource.data.token.size() < 4096
        && request.resource.data.updatedAt is timestamp;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /celebrationProfiles/{userId} {
      allow read: if isRegisteredMember();
      // Only celebration-related fields; written by app after profile save.
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly(["fullName", "dob", "anniversary", "anniversaryPartnerName", "familyMembers", "updatedAt"])
        && request.resource.data.fullName is string
        && request.resource.data.fullName.size() <= 120
        && request.resource.data.dob is string
        && request.resource.data.dob.size() <= 12
        && request.resource.data.anniversary is string
        && request.resource.data.anniversary.size() <= 12
        && request.resource.data.anniversaryPartnerName is string
        && request.resource.data.anniversaryPartnerName.size() <= 120
        && request.resource.data.familyMembers is list
        && request.resource.data.familyMembers.size() <= 20;
      allow delete: if request.auth != null
        && (request.auth.uid == userId || isAdmin());
    }

    match /celebrationWishes/{messageId} {
      // Members-only read so celebration names and wishes stay off the public internet.
      allow read: if isRegisteredMember();
      // Note: do not require createdAt is timestamp on create — FieldValue.serverTimestamp()
      // is a sentinel and does not satisfy timestamp checks in rules.
      allow create: if request.auth != null
        && request.resource.data.senderUid == request.auth.uid
        && request.resource.data.senderName is string
        && request.resource.data.senderName.size() > 0
        && request.resource.data.senderName.size() < 200
        && request.resource.data.threadId is string
        && request.resource.data.threadId.size() > 5
        && request.resource.data.threadId.size() < 80
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() < 2500;
      allow delete: if request.auth != null
        && (resource.data.senderUid == request.auth.uid || isAdmin());
    }

    match /chatMessages/{messageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.senderUid == request.auth.uid
        && request.resource.data.senderName is string
        && request.resource.data.senderName.size() > 0
        && request.resource.data.senderName.size() < 200
        && request.resource.data.createdAt is timestamp
        && request.resource.data.type == "text"
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() < 5000;
      allow update, delete: if false;
    }
  }
}
